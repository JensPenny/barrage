{
  "name": "Strike - Rust Dev Container",
  "image": "mcr.microsoft.com/devcontainers/rust:1",
  "features": {
    "ghcr.io/anthropics/devcontainer-features/claude-code:1": {},
    "ghcr.io/devcontainers/features/node:1": {}
  },
  "postCreateCommand": "cargo install cargo-watch",
  "runArgs": ["--cap-add=SYS_PTRACE", "--security-opt", "seccomp=unconfined", "--add-host=host.docker.internal:host-gateway"],
  "customizations": {
    "vscode": {
      "settings": {
        "editor.formatOnSave": true,
        "editor.defaultFormatter": "rust-lang.rust-analyzer",
        "files.autoSave": "onFocusChange",
        "terminal.integrated.defaultProfile.linux": "bash",
        "rust-analyzer.cargo.runBuildScripts": "always",
        "rust-analyzer.checkOnSave": true,
        "rust-analyzer.procMacro.enable": true,
        "rust-analyzer.diagnostics.enable": true
      },
      "extensions": [
        "rust-lang.rust-analyzer",
        "tamasfe.even-better-toml",
        "serayuzgur.crates",
        "eamodio.gitlens"
      ]
    }
  },
  "remoteUser": "vscode"
}
